    "plasmo": "^0.90.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@tanstack/react-query": "^5.0.0",
    "wagmi": "2.12.0",
    "viem": "2.21.54",
    "@coinbase/wallet-sdk": "^4.3.0"
  },
  "devDependencies": {
    "@types/canvas-confetti": "^1.6.4",
    "@types/chrome": "^0.0.287",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.7.0"
  },
  "manifest": {
    "host_permissions": [
      "https://*/*"
